<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_desktop_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="@dimen/desktop_padding_left_right"
    android:paddingEnd="@dimen/desktop_padding_left_right"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Conteúdo Superior: Relógio + Grid lado a lado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Widget Unificado de Relógio e Clima (Left Side) -->
        <LinearLayout
            android:id="@+id/ll_clock_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.30"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="@dimen/clock_margin_top"
            android:paddingBottom="@dimen/clock_margin_bottom"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/fl_mascot_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/iv_mascot"
                    android:layout_width="@dimen/mascot_size"
                    android:layout_height="@dimen/mascot_size"
                    android:scaleType="fitCenter"
                    android:contentDescription="Theme Symbol" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="#33FFFFFF" />

                <ImageView
                    android:id="@+id/iv_weather_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="Weather Icon" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp"
                    android:gravity="start">

                    <TextView
                        android:id="@+id/tv_weather_temp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:text="--°" />

                    <TextView
                        android:id="@+id/tv_weather_condition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="#BBFFFFFF"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="Clima" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextClock
                    android:id="@+id/tc_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="HH:mm"
                    android:format24Hour="HH:mm"
                    android:textSize="@dimen/clock_text_size"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />
                <TextClock
                    android:id="@+id/tc_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEEE, d 'de' MMMM"
                    android:format24Hour="EEEE, d 'de' MMMM"
                    android:textSize="@dimen/clock_date_text_size"
                    android:textAllCaps="true"
                    android:textColor="#AAFFFFFF"
                    android:layout_marginTop="-4dp"
                    android:letterSpacing="0.08" />
            </LinearLayout>
        </LinearLayout>

        <!-- Grade de Apps da Home (Right Side) -->
        <com.alisu.alauncher.workspace.WorkspaceLayout
            android:id="@+id/rv_home_desktop_apps"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.70"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- Dock Fixo Inferior -->
    <LinearLayout
        android:id="@+id/ll_dock_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="@dimen/dock_padding_top_bottom"
        android:paddingBottom="@dimen/dock_padding_top_bottom"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginBottom="@dimen/dock_margin_bottom">

        <com.alisu.alauncher.dock.DockLayout
            android:id="@+id/rv_home_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:scrollbars="none" />
    </LinearLayout>

</LinearLayout>
