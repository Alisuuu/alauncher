<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0E0E12"
    android:scrollbars="none"
    android:clickable="true"
    android:focusable="true"
    android:clipToPadding="false"
    android:paddingBottom="24dp"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="24dp">

        <!-- Título da Página de Widgets -->
        <TextView
            android:id="@+id/tv_widgets_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Widgets"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_gravity="start" />

        <!-- Colunas Lado a Lado -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Coluna Esquerda: Player de Música e Notas -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <!-- WIDGET: PLAYER DE MÚSICA PREMIUM -->
                <FrameLayout
                    android:id="@+id/card_music_player"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:padding="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_music_card"
                        android:padding="16dp">

                        <!-- Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_music_note_premium"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tv_music_player_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tocando Agora"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#B0FFFFFF"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/tv_music_player_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● Conectado"
                                android:textSize="9sp"
                                android:textColor="#4CAF50" />

                            <ImageView
                                android:id="@+id/iv_compact_toggle"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="6dp"
                                android:src="@drawable/ic_chevron_up"
                                android:alpha="0.5"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <!-- Album Art + Info -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <FrameLayout
                                android:id="@+id/fl_album_art"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:layout_marginEnd="12dp">

                                <ImageView
                                    android:id="@+id/iv_album_art"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_album_border"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_headphones_premium"
                                    android:alpha="0.4" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_song_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Nenhuma música tocando"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="marquee"
                                    android:marqueeRepeatLimit="marquee_forever"
                                    android:singleLine="true"
                                    android:freezesText="true" />

                                <TextView
                                    android:id="@+id/tv_song_artist"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Abra um app de música"
                                    android:textSize="11sp"
                                    android:textColor="#80FFFFFF"
                                    android:maxLines="1"
                                    android:layout_marginTop="2dp" />

                                <!-- Progress Bar -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="8dp">

                                    <TextView
                                        android:id="@+id/tv_current_time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0:00"
                                        android:textSize="9sp"
                                        android:textColor="#60FFFFFF"
                                        android:layout_marginEnd="4dp" />

                                    <FrameLayout
                                        android:id="@+id/fl_progress_bar"
                                        android:layout_width="0dp"
                                        android:layout_height="4dp"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_music_progress_bar">
                                        <View
                                            android:id="@+id/view_progress_fill"
                                            android:layout_width="0dp"
                                            android:layout_height="match_parent"
                                            android:background="@drawable/bg_music_progress_active" />
                                        <View
                                            android:id="@+id/view_progress_thumb"
                                            android:layout_width="12dp"
                                            android:layout_height="12dp"
                                            android:layout_gravity="center_vertical|start"
                                            android:translationX="-6dp"
                                            android:background="@drawable/bg_music_thumb_glow"
                                            android:visibility="gone" />
                                    </FrameLayout>

                                    <TextView
                                        android:id="@+id/tv_total_time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0:00"
                                        android:textSize="9sp"
                                        android:textColor="#60FFFFFF"
                                        android:layout_marginStart="4dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Controles de Transporte -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingBottom="2dp">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_music_btn_control"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginEnd="14dp">
                                <ImageView
                                    android:id="@+id/iv_prev"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_skip_prev" />
                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btn_play_pause"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_music_btn_play_glow"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginStart="6dp"
                                android:layout_marginEnd="6dp">
                                <ImageView
                                    android:id="@+id/iv_play_pause"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_play_premium" />
                            </FrameLayout>

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_music_btn_control"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginStart="14dp">
                                <ImageView
                                    android:id="@+id/iv_next"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_skip_next" />
                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btn_queue"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_music_btn_control"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginStart="14dp">
                                <ImageView
                                    android:id="@+id/iv_queue"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_queue"
                                    android:alpha="0.5" />
                            </FrameLayout>
                        </LinearLayout>

                    </LinearLayout>
                </FrameLayout>

                <!-- Widget de Notas Rápidas -->
                <LinearLayout
                    android:id="@+id/card_widget_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tv_widget_notes_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notas Rápidas"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_widget_notes"
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:background="@null"
                        android:gravity="top|start"
                        android:hint="Escreva algo aqui..."
                        android:textColorHint="#88CCCCCC"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:importantForAutofill="no"
                        android:inputType="textMultiLine" />
                </LinearLayout>
            </LinearLayout>

            <!-- Coluna Direita: Adicionar Widget + Container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <!-- Botão para Adicionar Widgets -->
                <LinearLayout
                    android:id="@+id/btn_add_android_widget"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/iv_add_widget_icon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_add"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_add_widget_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adicionar Widget do Android"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <!-- Container para os widgets adicionados -->
                <LinearLayout
                    android:id="@+id/ll_android_widgets_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp"
                    android:animateLayoutChanges="true" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
