<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow externo -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#55FF6D00"
                android:endColor="#00FF6D00"
                android:angle="135" />
            <size
                android:width="56dp"
                android:height="56dp" />
        </shape>
    </item>
    <!-- Botão principal -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#FFFF6D00"
                android:centerColor="#FFFF3D00"
                android:endColor="#FFD50000"
                android:angle="135" />
        </shape>
    </item>
</layer-list>
