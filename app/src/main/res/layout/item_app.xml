<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <!-- Container para bordas/efeitos (Substitui fl_icon_container) -->
    <FrameLayout
        android:id="@+id/fl_icon_container"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Fundo/Textura do Card -->
        <ImageView
            android:id="@+id/iv_card_texture"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:visibility="gone" />

        <!-- Ícone do App -->
        <ImageView
            android:id="@+id/iv_app_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:contentDescription="Icon" />

    </FrameLayout>

    <!-- Botão de Deletar -->
    <ImageView
        android:id="@+id/btn_delete_app"
        android:layout_width="20dp"
        android:layout_height="20dp"
        app:layout_constraintTop_toTopOf="@id/fl_icon_container"
        app:layout_constraintEnd_toEndOf="@id/fl_icon_container"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="-4dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/bg_circle_red"
        android:padding="5dp"
        android:visibility="gone"
        app:tint="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Delete app" />

    <!-- Nome do App -->
    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/fl_icon_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="App Name"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
