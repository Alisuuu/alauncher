<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- 97% - Painel de Widgets estilo pasta -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="97"
        android:background="#CC0E0E12"
        android:clickable="true"
        android:focusable="true">

        <!-- Conteúdo -->
        <ScrollView
            android:id="@+id/sv_widgets_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingTop="16dp"
            android:paddingBottom="40dp"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                    <!-- WIDGET: PLAYER DE MÚSICA PREMIUM -->
                <FrameLayout
                    android:id="@+id/card_music_player"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:padding="3dp">

                    <ImageView
                        android:id="@+id/iv_music_card_backdrop"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_music_card"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_music_note_premium"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tv_music_player_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/now_playing"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#B0FFFFFF"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/tv_music_player_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/connected"
                                android:textSize="10sp"
                                android:textColor="#4CAF50" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <FrameLayout
                                android:id="@+id/fl_album_art"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:layout_marginEnd="16dp">

                                <ImageView
                                    android:id="@+id/iv_album_art"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_album_border"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_headphones_premium"
                                    android:alpha="0.4" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_song_title"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/no_music"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"
                                    android:maxLines="1"
                                    android:ellipsize="marquee"
                                    android:marqueeRepeatLimit="marquee_forever"
                                    android:singleLine="true"
                                    android:freezesText="true" />

                                <TextView
                                    android:id="@+id/tv_song_artist"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/open_music_app"
                                    android:textSize="12sp"
                                    android:textColor="#80FFFFFF"
                                    android:maxLines="1"
                                    android:layout_marginTop="3dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="12dp">

                                    <TextView
                                        android:id="@+id/tv_current_time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0:00"
                                        android:textSize="9sp"
                                        android:textColor="#60FFFFFF"
                                        android:fontFamily="sans-serif-medium"
                                        android:layout_marginEnd="6dp" />

                                    <FrameLayout
                                        android:id="@+id/fl_progress_bar"
                                        android:layout_width="0dp"
                                        android:layout_height="6dp"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_music_progress_bar">

                                        <View
                                            android:id="@+id/view_progress_fill"
                                            android:layout_width="0dp"
                                            android:layout_height="match_parent"
                                            android:background="@drawable/bg_music_progress_active" />

                                        <View
                                            android:id="@+id/view_progress_thumb"
                                            android:layout_width="14dp"
                                            android:layout_height="14dp"
                                            android:layout_gravity="center_vertical|start"
                                            android:translationX="-7dp"
                                            android:background="@drawable/bg_music_thumb_glow"
                                            android:visibility="gone" />
                                    </FrameLayout>

                                    <TextView
                                        android:id="@+id/tv_total_time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0:00"
                                        android:textSize="9sp"
                                        android:textColor="#60FFFFFF"
                                        android:fontFamily="sans-serif-medium"
                                        android:layout_marginStart="6dp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:paddingBottom="4dp">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_music_btn_control"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginEnd="16dp">

                                <ImageView
                                    android:id="@+id/iv_prev"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_skip_prev" />
                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btn_play_pause"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_music_btn_play_glow"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp">

                                <ImageView
                                    android:id="@+id/iv_play_pause"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_play_premium" />
                            </FrameLayout>

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_music_btn_control"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginStart="16dp">

                                <ImageView
                                    android:id="@+id/iv_next"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_skip_next" />
                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btn_queue"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_music_btn_control"
                                android:clickable="true"
                                android:focusable="true"
                                android:layout_marginStart="16dp">

                                <ImageView
                                    android:id="@+id/iv_queue"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_music_queue"
                                    android:alpha="0.5" />
                            </FrameLayout>
                        </LinearLayout>

                    </LinearLayout>
                </FrameLayout>

                <!-- Widget de Notas Rápidas -->
                <LinearLayout
                    android:id="@+id/card_widget_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tv_widget_notes_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/quick_notes"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/et_widget_notes"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:background="@null"
                        android:gravity="top|start"
                        android:hint="@string/notes_hint"
                        android:textColorHint="#88CCCCCC"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:importantForAutofill="no"
                        android:inputType="textMultiLine" />
                </LinearLayout>

                <!-- Botão para Adicionar Widgets do Android -->
                <LinearLayout
                    android:id="@+id/btn_add_android_widget"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:id="@+id/iv_add_widget_icon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_add"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_add_widget_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_android_widget"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <!-- Container para os widgets adicionados -->
                <LinearLayout
                    android:id="@+id/ll_android_widgets_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp"
                    android:animateLayoutChanges="true" />

                </LinearLayout>
            </ScrollView>

            <!-- Alça vertical na borda direita do painel -->
            <View
                android:id="@+id/v_widgets_handle"
                android:layout_width="5dp"
                android:layout_height="140dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_drag_handle" />
        </FrameLayout>

        <!-- 3% - Overlay para fechar (desktop visível atrás) -->
        <View
            android:id="@+id/v_widgets_close_overlay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:background="#99000000"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
