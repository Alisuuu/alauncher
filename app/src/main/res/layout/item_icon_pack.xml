<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_icon_pack_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Radio selection dot -->
    <View
        android:id="@+id/iv_icon_pack_check_dot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginEnd="12dp" />

    <!-- Icon pack app icon -->
    <ImageView
        android:id="@+id/iv_icon_pack_app_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp" />

    <!-- Icon pack info labels -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_icon_pack_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tv_icon_pack_package"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#88FFFFFF"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Previews of 4 icons -->
    <LinearLayout
        android:id="@+id/ll_icon_pack_previews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_preview_1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/iv_preview_2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/iv_preview_3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp" />

        <ImageView
            android:id="@+id/iv_preview_4"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>
