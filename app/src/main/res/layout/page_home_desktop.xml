<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_desktop_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Widget Unificado de Relógio e Clima -->
    <LinearLayout
        android:id="@+id/ll_clock_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_marginTop="0dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Área Superior: Símbolo + Info de Clima -->
        <LinearLayout
            android:id="@+id/fl_mascot_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            
            <ImageView
                android:id="@+id/iv_mascot"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="fitCenter"
                android:contentDescription="Theme Symbol" />
            
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="#33FFFFFF" />

            <ImageView
                android:id="@+id/iv_weather_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:scaleType="fitCenter"
                android:contentDescription="Weather Icon" />
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:gravity="start">
                
                <TextView
                    android:id="@+id/tv_weather_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:text="--°" />
                
                <TextView
                    android:id="@+id/tv_weather_condition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#BBFFFFFF"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="@string/weather_default" />
            </LinearLayout>
        </LinearLayout>

        <!-- Área Inferior: Hora e Data -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextClock
                android:id="@+id/tc_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:textSize="50sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />
            <TextClock
                android:id="@+id/tc_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="EEEE, d 'de' MMMM"
                android:format24Hour="EEEE, d 'de' MMMM"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textColor="#AAFFFFFF"
                android:layout_marginTop="-6dp"
                android:letterSpacing="0.08" />
        </LinearLayout>
    </LinearLayout>

    <!-- Grade de Apps da Home -->
    <com.alisu.alauncher.workspace.WorkspaceLayout
        android:id="@+id/rv_home_desktop_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- Dock Fixo Inferior (Parte integrante do Desktop) -->
    <LinearLayout
        android:id="@+id/ll_dock_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginBottom="24dp"
        android:visibility="gone">

        <!-- Grid de Atalhos Rápidos (Dock) -->
        <com.alisu.alauncher.dock.DockLayout
            android:id="@+id/rv_home_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:scrollbars="none" />
    </LinearLayout>

</LinearLayout>
